<UserControl x:Class="IntuneAdminTool.Views.WindowsUpdatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Loading Windows Updates data..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" HorizontalAlignment="Center" Margin="0,10"/>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="10,5" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"/>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="10">
            <!-- Update Rings Tab -->
            <TabItem Header="Update Rings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding UpdateRings}" SelectedItem="{Binding SelectedRing}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="250"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="250"/>
                            <DataGridTextColumn Header="Quality Deferral (days)" Binding="{Binding QualityUpdatesDeferralPeriodInDays}" Width="150"/>
                            <DataGridTextColumn Header="Feature Deferral (days)" Binding="{Binding FeatureUpdatesDeferralPeriodInDays}" Width="150"/>
                            <DataGridTextColumn Header="Servicing Channel" Binding="{Binding BusinessReadyUpdatesOnly}" Width="140"/>
                            <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModifiedDateTime, StringFormat=g}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Grid.Row="1" Header="Update Ring Details" Margin="0,8,0,0"
                              Visibility="{Binding SelectedRing, Converter={StaticResource NullToCollapsed}}">
                        <Grid Margin="10" DataContext="{Binding SelectedRing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Display Name:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DisplayName}" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Servicing Channel:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding BusinessReadyUpdatesOnly}" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Quality Deferral (days):" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding QualityUpdatesDeferralPeriodInDays}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Feature Deferral (days):" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding FeatureUpdatesDeferralPeriodInDays}" Margin="0,2"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Created:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CreatedDateTime, StringFormat=g}" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Last Modified:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding LastModifiedDateTime, StringFormat=g}" Margin="0,2"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Feature Updates Tab -->
            <TabItem Header="Feature Updates" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding FeatureUpdates}" SelectedItem="{Binding SelectedFeatureUpdate}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="250"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="250"/>
                            <DataGridTextColumn Header="Target Version" Binding="{Binding FeatureUpdateVersion}" Width="200"/>
                            <DataGridTextColumn Header="Rollout Start" Binding="{Binding RolloutSettings}" Width="180"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedDateTime, StringFormat=g}" Width="140"/>
                            <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModifiedDateTime, StringFormat=g}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Grid.Row="1" Header="Feature Update Details" Margin="0,8,0,0"
                              Visibility="{Binding SelectedFeatureUpdate, Converter={StaticResource NullToCollapsed}}">
                        <Grid Margin="10" DataContext="{Binding SelectedFeatureUpdate}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Display Name:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DisplayName}" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Target Version:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding FeatureUpdateVersion}" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Rollout Start:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RolloutSettings}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Last Modified:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding LastModifiedDateTime, StringFormat=g}" Margin="0,2"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Driver Updates Tab -->
            <TabItem Header="Driver Updates" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding DriverUpdates}" SelectedItem="{Binding SelectedDriverUpdate}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="300"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="300"/>
                            <DataGridTextColumn Header="Approval Type" Binding="{Binding ApprovalType}" Width="150"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedDateTime, StringFormat=g}" Width="140"/>
                            <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModifiedDateTime, StringFormat=g}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GroupBox Grid.Row="1" Header="Driver Update Details" Margin="0,8,0,0"
                              Visibility="{Binding SelectedDriverUpdate, Converter={StaticResource NullToCollapsed}}">
                        <Grid Margin="10" DataContext="{Binding SelectedDriverUpdate}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Display Name:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DisplayName}" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Approval Type:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding ApprovalType}" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Created:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatedDateTime, StringFormat=g}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Last Modified:" FontWeight="SemiBold" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding LastModifiedDateTime, StringFormat=g}" Margin="0,2"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
